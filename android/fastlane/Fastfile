# update_fastlane

default_platform(:android)

platform :android do

  desc "Run tests, build and distribute to Firebase"
  lane :test_and_distribute do

    # Unit tests
    sh("flutter test ../../test/ --reporter=compact")

    # Integration tests - only run locally, skip on CI
    unless ENV["CI"]
      sh("flutter test ../../integration_test/articles_flow_test.dart --reporter=compact")
      sh("flutter test ../../integration_test/app_flow_test.dart --reporter=compact")
    end

    # Build release APK
    sh("flutter build apk --release", chdir: "..")

    # Distribute to Firebase App Distribution
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID"],
      firebase_cli_token: ENV["FIREBASE_TOKEN"],
      android_artifact_type: "APK",
      android_artifact_path: "../build/app/outputs/flutter-apk/app-release.apk",
      groups: "testers",
      release_notes: "Release #{ENV["GITHUB_REF_NAME"]}"
    )

  end

end